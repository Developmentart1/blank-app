      ]
    },
    "okr": {
      "nombre": "Dashboard OKRs Q1",
      "widgets": [
        {"tipo": "gauge", "nombre": "Progreso Global", "meta": 100},
        {"tipo": "chart", "nombre": "OKRs por Área", "tipo_grafico": "radar"},
